# ==========================================
# Cấu hình Môi Trường - MBBank Panel PRO
# ==========================================
# Bạn có thể copy file này thành `.env` để tuỳ chỉnh các port nếu bị trùng lặp.

# 1. Port dành cho Backend API và Docker Production (Mặc định: 2001)
PORT=2001

# 2. Port dành cho Frontend Vue (Vite) chỉ dùng khi chạy Dev (Mặc định: 2000)
VITE_PORT=2000
